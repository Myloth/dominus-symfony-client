{
    "name": "myloth/dominus-symfony-admin",
    "type": "project",
    "license": "MIT",
    "description": "A minimal Symfony project recommended to create bare bones applications",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "friendsofsymfony/jsrouting-bundle": "^3.6.1",
        "nelmio/cors-bundle": "^2.6.1",
        "phpdocumentor/reflection-docblock": "^6.0.3",
        "phpstan/phpdoc-parser": "^2.3.2",
        "runtime/frankenphp-symfony": "^1.0",
        "sensiolabs/typescript-bundle": "^0.2.2",
        "symfony/asset-mapper": "7.4.*",
        "symfony/config": "^7.4.14",
        "symfony/console": "^7.4.14",
        "symfony/dependency-injection": "^7.4.14",
        "symfony/dotenv": "^7.4.14",
        "symfony/error-handler": "^7.4.14",
        "symfony/event-dispatcher": "^7.4.14",
        "symfony/flex": "^2.11.0",
        "symfony/form": "^7.4.14",
        "symfony/framework-bundle": "^7.4.14",
        "symfony/http-client": "^7.4.14",
        "symfony/http-foundation": "^7.4.14",
        "symfony/http-kernel": "^7.4.14",
        "symfony/intl": "^7.4.14",
        "symfony/monolog-bundle": "^3.11.2",
        "symfony/options-resolver": "^7.4.8",
        "symfony/property-access": "^7.4.8",
        "symfony/property-info": "7.4.*",
        "symfony/routing": "^7.4.13",
        "symfony/runtime": "^7.4.14",
        "symfony/security-bundle": "^7.4.14",
        "symfony/security-core": "^7.4.14",
        "symfony/security-http": "^7.4.14",
        "symfony/serializer": "^7.4.14",
        "symfony/stopwatch": "^7.4.8",
        "symfony/translation": "^7.4.14",
        "symfony/twig-bridge": "^7.4.14",
        "symfony/twig-bundle": "^7.4.14",
        "symfony/type-info": "^7.4.9",
        "symfony/validator": "^7.4.14",
        "symfony/var-exporter": "^7.4.14",
        "symfony/webpack-encore-bundle": ">=2.4.1",
        "symfony/yaml": "^7.4.14",
        "symfonycasts/sass-bundle": ">=0.10.0",
        "twig/extra-bundle": "^2.12|^3.24.0",
        "twig/twig": "^2.12|^3.27.1",
        "willdurand/js-translation-bundle": "^7.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    },
    "require-dev": {
        "symfony/debug-bundle": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*"
    }
}
