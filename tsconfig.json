{

  "include": [
    "./assets/ts/**/*",
    "./vendor/**/ts/*",
    "./node_modules/fos-router/ts/router.d.ts"
  ],
  "exclude": [
    "./public/js",
    "vendor/**/**.test-d.ts"
  ],
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017", "DOM"],
    "module": "es2015",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./public/js",
    "rootDirs": ["./assets/ts", "./vendor/**/ts/*"],
    "sourceMap": true,
    "moduleResolution": "node",
    "typeRoots": ["./node_modules/@types"],
    "allowJs": true,
    "resolveJsonModule": true,
    "types": ["jquery"]
  },
}