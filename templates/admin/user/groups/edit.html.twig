{% trans_default_domain 'users' %}
{% extends 'admin/base.html.twig' %}

{% block pageActions %}
    <div class="page-actions">
        <a href="/back.html" class="btn-secondary">Retour</a>
        <button id="saveButton" class="btn-primary" type="submit">Enregistrer</button>

    </div>
{% endblock %}

{% if group is not defined %}
    {% set page_title = 'groups.create.title' | trans %}
{% else %}
    {% set page_title = 'groups.edit.title' | trans({'%group%': group.name}) %}
{% endif %}

{% block pageContent %}
    <div id="dataDiv" data-id="{% if group is not defined %}{% else %}{{ group.id }}{% endif %}"></div>
    <div class="content-wrapper">
        <!-- Section principale (2/3) -->
        <div class="main-section">
            <div class="tabs">
                <ul class="tab-list">
                    <li class="tab-item active" data-tab="general">Général</li>
                    <!-- Autres onglets peuvent être ajoutés ici -->
                </ul>
            </div>

            <div class="tab-content active" id="tab-general">
                {{ form_start(form, {'attr': {'class': 'edit-form'}} ) }}
                <div class="form-row">
                    <div class="form-group">
                        {{ form_row(form.name) }}
                    </div>
                    <div class="form-group">
                        {{ form_row(form.roles, {'attr': {'class': 'select2'}}) }}
                    </div>
                </div>
                {{ form_end(form) }}
            </div>
        </div>

        <!-- Section d'aide (1/3) -->
        <div class="help-section">
            <div class="help-content">
                <div class="help-header">
                    <h2>Aide</h2>
                    <button class="btn-edit-help" id="editHelpBtn">
                        <i class="fas fa-edit"></i>
                    </button>
                </div>
                <div class="help-text" id="helpText">
                    <p>Cette page permet de modifier les informations d'un utilisateur.</p>
                    <ul>
                        <li>Le nom d'utilisateur ne peut pas être modifié</li>
                        <li>L'email doit être une adresse valide</li>
                        <li>Le mot de passe est optionnel. Ne le remplissez que si vous souhaitez le modifier</li>
                        <li>Vous pouvez sélectionner plusieurs groupes pour l'utilisateur</li>
                        <li>Le statut permet d'activer ou désactiver l'accès de l'utilisateur</li>
                    </ul>
                </div>
                <div class="help-edit hidden" id="helpEdit">
                    <textarea id="helpTextArea"></textarea>
                    <div class="help-edit-actions">
                        <button class="btn-primary" id="saveHelpBtn">Enregistrer</button>
                        <button class="btn-secondary" id="cancelHelpBtn">Annuler</button>
                    </div>
                </div>
            </div>
        </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('group-edit') }}
{% endblock %}